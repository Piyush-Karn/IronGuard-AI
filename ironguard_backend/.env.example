# IronGuard Backend Environment Variables (Example)
# Rename this file to .env and fill in your real keys.

# Generate once: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
IG_SECRET_ENCRYPTION_KEY=your-fernet-key-here

# MongoDB
MONGO_URL=mongodb://mongodb:27017

# ChromaDB
CHROMA_HOST=chromadb
CHROMA_PORT=8000

# LLM Provider API Keys
GEMINI_API_KEY=REPLACE_ME
MISTRAL_API_KEY=REPLACE_ME

# Scaling & Performance
RATELIMIT_USER_RPM=20
RATELIMIT_PROVIDER_RPM=60

# Advanced Features
CONTEXT_WINDOW_SIZE=5
CONTEXT_RISK_BONUS=20
BEHAVIORAL_ESCALATION_THRESHOLD=15
